# Backend Production Environment Variables
# Copy this file to .env and fill in the values for AWS Deployment

SECRET_KEY=your-super-secret-random-key-here
DEBUG=False

# Your Neon serverless PostgreSQL connection string
DATABASE_URL=postgresql://user:password@endpoint.neon.tech/dbname

# The public IP or domain of your AWS EC2 instance (e.g., 54.123.45.67, api.maxcap.com)
ALLOWED_HOSTS=54.123.45.67,localhost,127.0.0.1

# The URL of your React frontend to allow cross-origin requests
CORS_ALLOWED_ORIGINS=http://54.123.45.67,http://localhost
